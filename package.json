{
  "name": "nexus-platform",
  "version": "1.0.0",
  "description": "Nexus Platform - Multi-tenant SaaS médico com RLS PostgreSQL",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api-server && npm run dev",
    "dev:web": "cd apps/web-portal && npm run dev",
    "start": "cd apps/api-server && npm start",
    "start:all": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "start:api": "cd apps/api-server && npm start",
    "start:web": "cd apps/web-portal && npm start",
    "build": "npm run build:api && npm run build:web",
    "build:api": "cd apps/api-server && npm run build",
    "build:web": "cd apps/web-portal && npm run build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "prettier --write . && eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:rls": "jest --testPathPattern='rls.test.js'",
    "test:e2e": "playwright test",
    "db:migrate": "psql $DATABASE_URL -f supabase/migrations/*.sql",
    "db:migrate:staging": "echo 'Set STAGING_DATABASE_URL in .env'",
    "db:migrate:prod": "echo 'Set PROD_DATABASE_URL in .env'",
    "db:migrate:up": "supabase migration up",
    "db:migrate:down": "supabase migration down",
    "db:reset": "npm run docker:down && docker volume rm nexus-platform_postgres_data 2>/dev/null || true && npm run db:setup",
    "db:seed:dev": "psql $DATABASE_URL -f packages/database/seeds/dev-seed.sql",
    "db:seed:prod": "psql $DATABASE_URL -f packages/database/seeds/prod-seed.sql",
    "db:setup": "docker compose up -d && sleep 10 && npm run db:migrate && npm run db:seed:dev",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down -v --remove-orphans",
    "docker:logs": "docker compose logs -f",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:db:diff": "supabase db diff",
    "supabase:db:dump": "supabase db dump --db-url $DATABASE_URL",
    "ci": "npm run lint && npm run format:check && npm run test && npm run test:rls && npm run build",
    "preci": "npm install",
    "postci": "npm run db:migrate",
    "deploy:render": "npm run build && npm run db:migrate",
    "deploy:staging": "npm run ci && echo 'npm run db:migrate:staging'",
    "deploy:prod": "npm run ci && echo 'npm run db:migrate:prod'"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "pg": "^8.11.5",
    "prettier": "^3.2.5",
    "supabase": "^1.164.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
