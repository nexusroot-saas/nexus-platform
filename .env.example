# ─── BANCO DE DADOS ───────────────────────────────────────────────
# URL completa para conexão (produção/staging)
DATABASE_URL=postgresql://nexus:nexusdevpass@localhost:5432/nexus_dev

# Variáveis individuais (usadas em testes/Jest/CI)
PGUSER=nexus
PGPASSWORD=nexusdevpass
PGDATABASE=nexus_test
PGHOST=localhost
PGPORT=5432

# ─── SUPABASE ─────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ... # chave pública
SUPABASE_SERVICE_ROLE_KEY=eyJ... # NUNCA commitar o valor real

# ─── AUTENTICAÇÃO JWT ─────────────────────────────────────────────
JWT_SECRET=minimo-32-caracteres-aleatorios-aqui
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── FILA DE MENSAGERIA ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── WHATSAPP BUSINESS API ────────────────────────────────────────
WHATSAPP_BSP_PROVIDER=twilio
WHATSAPP_API_KEY=xxxx
WHATSAPP_PHONE_NUMBER_ID=xxxx
WHATSAPP_WEBHOOK_SECRET=xxxx

# ─── STORAGE ──────────────────────────────────────────────────────
STORAGE_BUCKET_LEGAL=legal-vault
STORAGE_BUCKET_CLINICAL=clinical-docs

# ─── AMBIENTE ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
